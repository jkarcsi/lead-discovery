DATABASE_URL="file:./dev.db"

# Crawler identity — a stable, identified User-Agent avoids blank-UA blocks.
CRAWLER_USER_AGENT="LeadBot/0.2"
CRAWLER_CONTACT_URL=""

# Source endpoints
OVERPASS_URL="https://overpass-api.de/api/interpreter"
# Public Overpass mirrors, tried in order when the primary rate-limits (429) or
# times out (504). Note: overpass-api.de is IPv6-only — on an IPv4-only host,
# rely on these mirrors or set OVERPASS_URL to one of them.
OVERPASS_MIRRORS="https://overpass.kumi.systems/api/interpreter,https://overpass.openstreetmap.ru/api/interpreter,https://maps.mail.ru/osm/tools/overpass/api/interpreter"
VIES_URL="https://ec.europa.eu/taxation_customs/vies/rest-api/check-vat-number"
# Generic directory connectors have no public default — set these to a real
# listing to collect them live (otherwise --live fails fast with a clear hint).
# DIRECTORY_URL="https://your-directory.example/api"
# HTML_DIRECTORY_URL="https://your-listing.example"

# --- Throughput knobs ---
# Per-host minimum gap between requests (ms). Keeps us under rate-limiters so we
# don't get IP-banned mid-crawl. Set 0 where the source allows it.
MIN_REQUEST_INTERVAL_MS="1000"
# Sources/pages fetched + parsed in parallel.
FETCH_CONCURRENCY="8"
# Transient-failure retries with exponential backoff.
FETCH_MAX_RETRIES="3"
FETCH_BACKOFF_BASE_MS="500"
# Per-request timeout (ms); a timed-out request is retried. Stops one hung site
# from stalling a run (esp. `enrich`, which scrapes arbitrary websites). 0 = off.
FETCH_TIMEOUT_MS="15000"
# Cache identical fetches within a run ("false" to disable).
FETCH_CACHE="true"
# DB bulk-insert batch size.
WRITE_BATCH_SIZE="500"
# Honor robots.txt (operator's choice; off by default).
RESPECT_ROBOTS="false"

# --- Optional operator utilities ---
PERSONAL_DATA_RETENTION_DAYS="365"
OUTREACH_ENABLED="false"

# EVNY sole-trader registry is sensitive personal data — OFF unless enabled.
EVNY_ENABLED="false"

# --- AI categorization (Claude Haiku via the Batches API) ---
# Classifies website text the keyword rules couldn't. Live mode needs a key;
# without it, `ai-categorize --live` fails fast and `refresh` skips the step.
# ANTHROPIC_API_KEY="sk-ant-..."
AI_CATEGORIZE_MODEL="claude-haiku-4-5"
