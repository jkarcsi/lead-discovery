generator client {
  provider = "prisma-client-js"
  // Repo lives on a shared drive used from both Windows and WSL/Linux; generate
  // engines for both so `prisma generate` on either host yields a working client.
  binaryTargets = ["native", "windows", "debian-openssl-3.0.x"]
}

datasource db {
  // SQLite in dev; switch to Postgres in production without schema changes.
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// A collected business. `dedupeKey` is the stable identity (VAT → domain →
// name+region) so re-collection merges rather than duplicates.
model Lead {
  id                 String       @id @default(cuid())
  dedupeKey          String       @unique
  legalName          String
  brandName          String?
  vatNumber          String?
  registrationNumber String?
  email              String?
  phone              String?
  website            String?
  domain             String?
  address            String?
  regionId           String? // Procura region id
  categories         String       @default("[]") // JSON: Procura category ids
  // Free-text categorization input (OSM tags + name + brand). Persisted so leads
  // can be re-categorized after a keyword change without re-fetching (recategorize).
  classificationText String?
  source             String // connector id, e.g. "overpass"
  sourceUrl          String?
  sourceLicense      String? // e.g. "ODbL"
  isPersonalData     Boolean      @default(false) // sole traders / named contacts
  gdprBasis          String       @default("legitimate_interest")
  qualityScore       Int          @default(0)
  lifecycle          String       @default("NEW") // NEW | CONTACTED | RESPONDED | REGISTERED | SUPPRESSED
  reviewStatus       String       @default("PENDING") // PENDING | APPROVED | REJECTED (human vetting)
  reviewNote         String?
  reviewedAt         DateTime?
  collectedAt        DateTime     @default(now())
  lastVerifiedAt     DateTime?
  // NAV (tax authority) signals — added by the `nav` enrichment step.
  taxStatus          String? // ACTIVE | SUSPENDED | CANCELLED | UNKNOWN
  debtFree           Boolean? // köztartozásmentes adózó
  employeeCount      Int?
  navCheckedAt       DateTime?
  contactCheckedAt   DateTime? // Tier-2 contact-page enrichment
  placesCheckedAt    DateTime? // Tier-2 Google Places enrichment
  auditEvents        AuditEvent[]

  @@index([regionId])
  @@index([lifecycle])
  @@index([reviewStatus])
}

// Resumable/incremental crawl cursor per (source, region): the highest page
// that returned results, so a re-run continues instead of re-scanning page 1.
model CrawlState {
  id        String   @id @default(cuid())
  source    String
  regionId  String
  lastPage  Int      @default(0)
  totalSeen Int      @default(0)
  lastRunAt DateTime @default(now())

  @@unique([source, regionId])
}

// Global do-not-contact list. Checked before every outreach send; opt-out and
// hard bounces add to it permanently.
model Suppression {
  id        String   @id @default(cuid())
  value     String   @unique // normalized email or domain
  kind      String // "EMAIL" | "DOMAIN"
  reason    String
  createdAt DateTime @default(now())
}

// Accountability trail (GDPR): how/when each lead was collected, contacted,
// opted out, verified, or converted.
model AuditEvent {
  id        String   @id @default(cuid())
  leadId    String?
  lead      Lead?    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type      String // COLLECTED | CONTACTED | OPT_OUT | DSAR | VERIFIED | REGISTERED
  meta      String?
  createdAt DateTime @default(now())
}
